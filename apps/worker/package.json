  "dependencies": {
    "@lp-admin/db": "workspace:*",
    "@lp-admin/shared": "workspace:*",
    "@lp-admin/templates": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250704.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.24.0"
  }
}
