# LP Admin Ubuntu 独立版配置
# 与 Cloudflare 站无任何数据或 API 连接，使用本机 SQLite 数据库

JWT_SECRET=change-me-in-production-use-openssl-rand

HOST=127.0.0.1
PORT=3000

# 部署模式（固定为独立自托管，勿改为 cloudflare）
DEPLOY_TARGET=self-hosted

# 服务器公网 IP（必填）
SERVER_IP=你的服务器IP

# 主域名（有域名时填写，无域名可填 IP）
PLATFORM_ZONE=example.com

DB_PATH=/opt/lp-admin/data/lp-admin.db
ASSETS_DIR=/opt/lp-admin/legacy/assets
ADMIN_DIR=/opt/lp-admin/admin

ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=admin123456
