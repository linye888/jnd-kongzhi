# LP Admin Ubuntu 自托管配置
# 复制为 apps/server/.env 后修改

# 必填：JWT 签名密钥（请使用随机长字符串）
JWT_SECRET=change-me-in-production-use-openssl-rand

# 服务监听
HOST=127.0.0.1
PORT=3000

# 主域名或服务器 IP（使用 IP 时所有域名按 A 记录解析）
PLATFORM_ZONE=example.com
SERVER_IP=
DEPLOY_TARGET=self-hosted
CNAME_TARGET=customers.example.com
FALLBACK_ORIGIN=origin.example.com

# 数据与静态资源路径（生产环境 install.sh 会自动设置）
DB_PATH=/opt/lp-admin/data/lp-admin.db
ASSETS_DIR=/opt/lp-admin/legacy/assets
ADMIN_DIR=/opt/lp-admin/admin

# 默认管理员（首次 seed 后请尽快修改密码）
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=admin123456

# 可选：Cloudflare API（用于域名 SSL 自动化，Ubuntu 自托管通常不需要）
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# CF_ZONE_ID=
