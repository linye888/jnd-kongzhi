{
  "name": "@lp-admin/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@lp-admin/db": "workspace:*",
    "@lp-admin/shared": "workspace:*",
    "@lp-admin/templates": "workspace:*",
    "@lp-admin/worker": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3",
    "node-cron": "^3.0.3",
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.32",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.8.3"
  }
}
